{% extends 'base.html.twig' %}

{% block title %}Mes Factures - DevisPro{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h1 class="h2 text-dark fw-bold mb-1">Facturation</h1>
            <p class="text-muted mb-0">Suivez vos factures, les statuts de paiement et vos recettes.</p>
        </div>
        <div>
            <a href="{{ path('app_quote_index') }}" class="btn btn-primary d-inline-flex align-items-center gap-2 px-4 py-2 shadow-sm">
                <i class="bi bi-plus-circle-fill"></i> Facturer un devis
            </a>
        </div>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="card-body p-0">
            {% if invoices is empty %}
                <div class="text-center py-5 px-4">
                    <div class="avatar avatar-xl bg-light text-muted rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                        <i class="bi bi-file-earmark-ruled fs-1"></i>
                    </div>
                    <h3 class="h5 fw-bold text-dark">Aucune facture pour le moment</h3>
                    <p class="text-muted mx-auto" style="max-width: 400px;">Générez votre première facture en quelques clics pour tester le système.</p>
                    <a href="{{ path('app_quote_index') }}" class="btn btn-outline-primary btn-sm">Créer un devis à facturer</a>                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light text-uppercase fs-7 fw-bold text-muted border-bottom text-nowrap">
                            <tr>
                                <th class="ps-4 py-3">N° Facture</th>
                                <th class="py-3">Client</th>
                                <th class="py-3">Montant</th>
                                <th class="py-3">Statut</th>
                                <th class="pe-4 py-3 text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="border-0">
                            {% for invoice in invoices %}
                                <tr>
                                    <td class="ps-4 py-3 fw-bold text-primary">{{ invoice.number }}</td>
                                    <td class="py-3">
                                        <div class="fw-medium text-dark">{{ invoice.customer.firstname }} {{ invoice.customer.lastname }}</div>
                                        {% if invoice.customer.company %}
                                            <small class="text-muted">{{ invoice.customer.company }}</small>
                                        {% endif %}
                                    </td>
                                    <td class="py-3 fw-bold text-dark">{{ invoice.totalTtcAmount|number_format(2, ',', ' ') }} €</td>
                                    <td class="py-3">
                                        {% if invoice.status == 'paid' %}
                                            <span class="badge bg-success bg-opacity-10 text-success px-2.5 py-1.5 fs-7">Payée</span>
                                        {% else %}
                                            <span class="badge bg-warning bg-opacity-10 text-warning px-2.5 py-1.5 fs-7">En attente</span>
                                        {% endif %}
                                    </td>
                                    <td class="pe-4 py-3 text-end text-nowrap">
                                        <a href="{{ path('app_invoice_show', {'id': invoice.id}) }}" class="btn btn-sm btn-light border" title="Voir"><i class="bi bi-eye"></i></a>

                                        <form action="{{ path('app_invoice_toggle_status', {'id': invoice.id}) }}" method="POST" style="display: inline;">
                                            <button type="submit" class="btn btn-sm btn-light border text-success" title="Encaisser / Changer le statut">
                                                <i class="bi bi-cash-stack"></i>
                                            </button>
                                        </form>

                                        <a href="{{ path('app_invoice_payments', {'id': invoice.id}) }}" class="btn btn-sm btn-light border text-info" title="Suivi des règlements"><i class="bi bi-info-circle"></i></a>

                                        <a href="{{ path('app_invoice_pdf', {'id': invoice.id}) }}" class="btn btn-sm btn-light border text-danger" title="Télécharger le PDF"><i class="bi bi-file-pdf"></i></a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
