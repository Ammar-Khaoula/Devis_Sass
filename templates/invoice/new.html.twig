{% extends 'base.html.twig' %}

{% block title %}Nouvelle Facture - DevisPro{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-6">
            <h1 class="h3 fw-bold text-dark mb-4">Émettre une nouvelle facture</h1>

            <div class="card border-0 shadow-sm rounded-3 bg-white p-4">
                <form method="POST">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary">Sélectionner le client</label>
                        <select name="customer" class="form-select" required>
                            <option value="">-- Choisir un client --</option>
                            {% for customer in customers %}
                                <option value="{{ customer.id }}">{{ customer.firstname }} {{ customer.lastname }} {% if customer.company %}({{ customer.company }}){% endif %}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-secondary">Montant de la facture (€)</label>
                        <input type="number" step="0.01" name="amount" class="form-control" placeholder="0,00" required>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a href="{{ path('app_invoice_index') }}" class="btn btn-light border">Annuler</a>
                        <button type="submit" class="btn btn-primary">Enregistrer la facture</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
