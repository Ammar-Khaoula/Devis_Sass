{% extends 'base.html.twig' %}

{% block title %}Historique {{ invoice.number }}{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="mb-4">
        <a href="{{ path('app_invoice_index') }}" class="btn btn-sm btn-light border">← Retour aux factures</a>
    </div>

    <h1 class="h3 fw-bold text-dark mb-4">Suivi des règlements — {{ invoice.number }}</h1>

    <div class="card border-0 shadow-sm p-4 bg-white mb-4" style="max-width: 650px;">
        <h5 class="fw-bold mb-3">Statut actuel</h5>
        <div class="d-flex align-items-center gap-3 mb-4">
            {% if invoice.status == 'paid' %}
                <span class="badge bg-success p-2 fs-6">💰 PAYÉE</span>
                <span class="text-muted">Le paiement de **{{ invoice.totalTtcAmount }} €** a été validé (Remis en main propre ou en ligne).</span>
            {% else %}
                <span class="badge bg-warning text-dark p-2 fs-6">⏳ EN ATTENTE</span>
                <span class="text-muted">Aucun règlement n'a encore été enregistré. Montant dû : **{{ invoice.totalTtcAmount }} €**.</span>
            {% endif %}
        </div>

        <hr class="my-3">

        <h6 class="fw-bold text-secondary text-uppercase small mb-3">Action de l'artisan</h6>
        <form action="{{ path('app_invoice_toggle_status', {'id': invoice.id}) }}" method="POST">
            {% if invoice.status == 'paid' %}
                <button type="submit" class="btn btn-outline-danger btn-sm">
                    <i class="bi bi-x-circle"></i> Annuler le paiement (repasser en attente)
                </button>
            {% else %}
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-cash-coin"></i> Encaisser : Marquer comme PAYÉE (Paiement main à main / En ligne)
                </button>
            {% endif %}
        </form>
    </div>
</div>
{% endblock %}
