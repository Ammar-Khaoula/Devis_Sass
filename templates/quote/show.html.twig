{% extends 'base.html.twig' %}

{% block title %}Devis {{ quote.number }} - DevisPro{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <nav aria-label="breadcrumb" class="mb-2">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="{{ path('app_quote_index') }}">Devis</a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{ quote.number }}</li>
                </ol>
            </nav>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 fw-bold text-dark mb-0">Détails du Devis</h1>
                <a href="{{ path('app_quote_edit', {'id': quote.id}) }}" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-pencil"></i> Modifier ce devis
                </a>
            </div>

            <div class="card border-0 shadow-sm rounded-3 bg-white p-4 mb-4">
                <div class="d-flex justify-content-between align-items-start border-bottom pb-3 mb-4">
                    <div>
                        <h4 class="fw-bold text-primary mb-1">{{ quote.number }}</h4>
                        <span class="text-muted">Créé le : {{ quote.createdAt|date('d/m/Y') }}</span>
                        <div class="mt-2 text-dark fw-semibold">Objet : {{ quote.title }}</div>
                    </div>
                    <div>
                        {% if quote.status == 'draft' %}
                            <span class="badge bg-secondary-subtle text-secondary border border-secondary rounded-pill px-3 py-1.5 text-capitalize">Brouillon</span>
                        {% elseif quote.status == 'sent' %}
                            <span class="badge bg-primary-subtle text-primary border border-primary rounded-pill px-3 py-1.5 text-capitalize">Envoyé</span>
                        {% elseif quote.status == 'accepted' %}
                            <span class="badge bg-success-subtle text-success border border-success rounded-pill px-3 py-1.5 text-capitalize">Accepté</span>
                        {% elseif quote.status == 'rejected' %}
                            <span class="badge bg-danger-subtle text-danger border border-danger rounded-pill px-3 py-1.5 text-capitalize">Refusé</span>
                        {% endif %}
                    </div>
                </div>

                <div class="bg-light p-3 rounded-3 mb-4">
                    <h6 class="text-muted text-uppercase fs-7 fw-bold mb-2">Informations Client</h6>
                    <div class="text-dark fw-bold fs-6">{{ quote.customer.company ?: 'Particulier' }}</div>
                    <div class="text-muted">{{ quote.customer.firstname }} {{ quote.customer.lastname }}</div>
                    <div class="text-muted small"><i class="bi bi-envelope me-1"></i> {{ quote.customer.email }}</div>
                </div>

                <h6 class="text-muted text-uppercase fs-7 fw-bold mb-3">Détail des prestations</h6>
                <div class="table-responsive mb-4">
                    <table class="table align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Description</th>
                                <th class="text-center" style="width: 10%;">Qté</th>
                                <th class="text-end" style="width: 20%;">Prix Unitaire HT</th>
                                <th class="text-center" style="width: 15%;">TVA</th>
                                <th class="text-end" style="width: 20%;">Total HT</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in quote.items %}
                                <tr class="border-bottom">
                                    <td class="fw-medium text-dark">{{ item.description }}</td>
                                    <td class="text-center">{{ item.quantity }}</td>
                                    <td class="text-end">{{ item.unitPrice|number_format(2, ',', ' ') }} €</td>
                                    <td class="text-center"><span class="badge bg-light text-dark border">{{ item.vatRate }} %</span></td>
                                    <td class="text-end fw-bold text-dark">{{ item.totalHt|number_format(2, ',', ' ') }} €</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                <div class="row justify-content-end">
                    <div class="col-12 col-md-5">
                        <div class="card bg-light border-0 p-3 rounded-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Total Hors Taxes :</span>
                                <span class="fw-semibold text-dark">{{ quote.totalAmount|number_format(2, ',', ' ') }} €</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Montant TVA :</span>
                                <span class="fw-semibold text-dark">{{ quote.totalVatAmount|number_format(2, ',', ' ') }} €</span>
                            </div>
                            <hr class="my-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold text-dark fs-5">Total TTC :</span>
                                <span class="fw-bold text-primary fs-4">{{ quote.totalTtcAmount|number_format(2, ',', ' ') }} €</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center">
                <a href="{{ path('app_quote_index') }}" class="btn btn-link text-decoration-none text-muted">
                    <i class="bi bi-arrow-left"></i> Retourner à la liste
                </a>
            </div>
            <div class="card border-danger-subtle bg-danger-subtle/10 p-3 rounded-3 mb-4 mt-5">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-danger fw-bold mb-1">Zone de danger</h6>
                        <p class="text-muted small mb-0">Cette action est irréversible. Toutes les lignes et données de ce devis seront définitivement effacées.</p>
                    </div>
                    <form method="post" action="{{ path('app_quote_delete', {'id': quote.id}) }}" onsubmit="return confirm('Êtes-vous absolument sûr de vouloir supprimer TOUT ce devis ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ quote.id) }}">
                        <button class="btn btn-sm btn-danger">
                            <i class="bi bi-trash"></i> Supprimer le devis entier
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
