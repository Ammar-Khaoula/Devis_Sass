{% extends 'base.html.twig' %}

{% block title %}Devis {{ quote.number }} - DevisPro{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <nav aria-label="breadcrumb" class="mb-2">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="{{ path('app_quote_index') }}">Devis</a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{ quote.number }}</li>
                </ol>
            </nav>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 fw-bold text-dark mb-0">Détails du Devis</h1>
                <a href="{{ path('app_quote_edit', {'id': quote.id}) }}" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Modifier ce devis</a>
            </div>

            <div class="card border-0 shadow-sm rounded-3 bg-white p-4">
                <div class="d-flex justify-content-between border-bottom pb-3 mb-4">
                    <div>
                        <h4 class="fw-bold text-primary mb-1">{{ quote.number }}</h4>
                        <span class="text-muted">Créé le : {{ quote.createdAt|date('d/m/Y') }}</span>
                    </div>
                    <div>
                        {% if quote.status == 'draft' %}
                            <span class="badge bg-secondary border p-2 text-capitalize">Brouillon</span>
                        {% elseif quote.status == 'sent' %}
                            <span class="badge bg-primary border p-2 text-capitalize">Envoyé</span>
                        {% elseif quote.status == 'accepted' %}
                            <span class="badge bg-success border p-2 text-capitalize">Accepté</span>
                        {% elseif quote.status == 'rejected' %}
                            <span class="badge bg-danger border p-2 text-capitalize">Refusé</span>
                        {% endif %}
                    </div>
                </div>

                <div class="mb-4">
                    <h6 class="text-muted text-uppercase small font-weight-bold">Objet du Devis</h6>
                    <p class="fs-5 text-dark fw-semibold">{{ quote.title }}</p>
                </div>

                <div class="bg-light p-3 rounded mb-4">
                    <h6 class="text-muted text-uppercase small font-weight-bold mb-2">Informations Client</h6>
                    <div class="text-dark fw-bold">{{ quote.customer.company ?: 'Particulier' }}</div>
                    <div class="text-muted">{{ quote.customer.firstname }} {{ quote.customer.lastname }}</div>
                    <div class="text-muted small"><i class="bi bi-envelope me-1"></i> {{ quote.customer.email }}</div>
                </div>

                <div class="border-top pt-3 d-flex justify-content-between align-items-center">
                    <span class="fs-5 text-muted fw-bold">Montant Total Initial :</span>
                    <span class="fs-3 fw-bold text-dark">{{ quote.totalAmount }} € HT</span>
                </div>
            </div>

            <div class="text-center mt-4">
                <a href="{{ path('app_quote_index') }}" class="btn btn-link text-decoration-none text-muted"><i class="bi bi-arrow-left"></i> Retourner à la liste</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
