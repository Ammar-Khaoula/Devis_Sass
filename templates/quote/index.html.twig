{% extends 'base.html.twig' %}

{% block title %}Mes Devis - DevisPro{% endblock %}

{% block body %}
<div class="container mt-4">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show shadow-sm border-0" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Tableau de bord</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Devis</li>
                </ol>
            </nav>
            <h1 class="h3 fw-bold text-dark mb-0">Gestion de mes devis</h1>
        </div>
        <a href="{{ path('app_quote_new') }}" class="btn btn-primary d-inline-flex align-items-center gap-2 shadow-sm">
            <i class="bi bi-plus-lg"></i> Nouveau devis
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-3 bg-white">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-uppercase fs-7 text-muted fw-bold border-bottom">
                    <tr>
                        <th class="ps-4">Numéro</th>
                        <th>Objet / Titre</th>
                        <th>Client</th>
                        <th>Montant HT</th>
                        <th>Statut</th>
                        <th>Créé le</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for quote in quotes %}
                    <tr class="border-bottom">
                        <td class="ps-4 fw-bold text-dark">{{ quote.number }}</td>
                        <td>
                            <div class="fw-semibold text-dark">{{ quote.title }}</div>
                        </td>
                        <td>
                            <span class="badge bg-light text-dark border p-2">
                                <i class="bi bi-person me-1"></i>
                                {{ quote.customer.company ?: (quote.customer.firstname ~ ' ' ~ quote.customer.lastname) }}
                            </span>
                        </td>
                        <td class="fw-bold text-dark">{{ quote.totalAmount }} €</td>
                        <td>
                            {% if quote.status == 'draft' %}
                                <span class="badge bg-secondary-subtle text-secondary border border-secondary rounded-pill px-2.5 py-1 text-capitalize">Brouillon</span>
                            {% elseif quote.status == 'sent' %}
                                <span class="badge bg-primary-subtle text-primary border border-primary rounded-pill px-2.5 py-1 text-capitalize">Envoyé</span>
                            {% elseif quote.status == 'accepted' %}
                                <span class="badge bg-success-subtle text-success border border-success rounded-pill px-2.5 py-1 text-capitalize">Accepté</span>
                            {% elseif quote.status == 'rejected' %}
                                <span class="badge bg-danger-subtle text-danger border border-danger rounded-pill px-2.5 py-1 text-capitalize">Refusé</span>
                            {% endif %}
                        </td>
                        <td class="text-muted fs-7">{{ quote.createdAt|date('d/m/Y') }}</td>
                        <td class="text-end pe-4">
                            <div class="d-inline-flex gap-1">
                                <a href="{{ path('app_quote_show', {'id': quote.id}) }}" class="btn btn-sm btn-light border" title="Voir les détails">
                                    <i class="bi bi-eye text-dark"></i>
                                </a>
                                <a href="{{ path('app_quote_edit', {'id': quote.id}) }}" class="btn btn-sm btn-light border" title="Modifier">
                                    <i class="bi bi-pencil text-primary"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center py-5">
                            <div class="text-muted mb-3"><i class="bi bi-file-earmark-text fs-1"></i></div>
                            <h6 class="fw-semibold text-dark mb-1">Aucun devis trouvé</h6>
                            <p class="text-muted small mb-3">Commencez dès maintenant par créer votre premier devis pro.</p>
                            <a href="{{ path('app_quote_new') }}" class="btn btn-sm btn-primary">Créer un devis</a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
