{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}

    <div class="row g-3">
        <div class="col-md-6">
            {{ form_label(form.firstname, null, {'label_attr': {'class': 'form-label fw-semibold text-dark'}}) }}
            {{ form_widget(form.firstname) }}
            <div class="text-danger small mt-1">{{ form_errors(form.firstname) }}</div>
        </div>

        <div class="col-md-6">
            {{ form_label(form.lastname, null, {'label_attr': {'class': 'form-label fw-semibold text-dark'}}) }}
            {{ form_widget(form.lastname) }}
            <div class="text-danger small mt-1">{{ form_errors(form.lastname) }}</div>
        </div>

        <div class="col-md-6">
            {{ form_label(form.email, null, {'label_attr': {'class': 'form-label fw-semibold text-dark'}}) }}
            {{ form_widget(form.email) }}
            <div class="text-danger small mt-1">{{ form_errors(form.email) }}</div>
        </div>

        <div class="col-md-6">
            {{ form_label(form.phone, null, {'label_attr': {'class': 'form-label fw-semibold text-dark'}}) }}
            {{ form_widget(form.phone) }}
            <div class="text-danger small mt-1">{{ form_errors(form.phone) }}</div>
        </div>

        <div class="col-12">
            {{ form_label(form.company, null, {'label_attr': {'class': 'form-label fw-semibold text-dark'}}) }}
            {{ form_widget(form.company) }}
            <div class="text-danger small mt-1">{{ form_errors(form.company) }}</div>
        </div>

        <div class="col-12">
            {{ form_label(form.address, null, {'label_attr': {'class': 'form-label fw-semibold text-dark'}}) }}
            {{ form_widget(form.address) }}
            <div class="text-danger small mt-1">{{ form_errors(form.address) }}</div>
        </div>

        <div class="col-md-6">
            {{ form_label(form.city, null, {'label_attr': {'class': 'form-label fw-semibold text-dark'}}) }}
            {{ form_widget(form.city) }}
            <div class="text-danger small mt-1">{{ form_errors(form.city) }}</div>
        </div>

        <div class="col-md-6">
            {{ form_label(form.country, null, {'label_attr': {'class': 'form-label fw-semibold text-dark'}}) }}
            {{ form_widget(form.country) }}
            <div class="text-danger small mt-1">{{ form_errors(form.country) }}</div>
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
        <a href="{{ path('app_customer_index') }}" class="btn btn-light border px-4">Annuler</a>
        <button type="submit" class="btn btn-primary px-4">{{ button_label|default('Enregistrer') }}</button>
    </div>

{{ form_end(form) }}
