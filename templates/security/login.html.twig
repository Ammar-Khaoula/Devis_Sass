{% extends 'base.html.twig' %}

{% block title %}Connexion - DevisPro{% endblock %}

{% block body %}
<div class="container">
    <div class="row justify-content-center align-items-center min-vh-100 py-5">
        <div class="col-12 col-md-8 col-lg-6 col-xl-5">

            <div class="text-center mb-4">
                <h2 class="fw-bold text-primary"><i class="bi bi-file-earmark-text-fill"></i> DevisPro</h2>
                <p class="text-muted">Accédez à votre espace de facturation</p>
            </div>

            <div class="card border-0 shadow rounded-3 p-3 p-md-4 bg-white">
                <div class="card-body">

                    <form method="post">
                        {% if error %}
                            <div class="alert alert-danger border-0 shadow-sm small mb-4 d-flex align-items-center gap-2" role="alert">
                                <i class="bi bi-exclamation-circle-fill"></i>
                                <div>{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                            </div>
                        {% endif %}

                        {% if app.user %}
                            <div class="alert alert-info border-0 small mb-4">
                                Vous êtes connecté en tant que {{ app.user.userIdentifier }}, <a href="{{ path('app_logout') }}" class="fw-bold">Déconnexion</a>
                            </div>
                        {% endif %}

                        <div class="mb-3">
                            <label for="inputEmail" class="form-label fw-semibold">Adresse Email</label>
                            <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" autocomplete="email" placeholder="name@example.com" required autofocus>
                        </div>

                        <div class="mb-3">
                            <label for="inputPassword" class="form-label fw-semibold">Mot de passe</label>
                            <input type="password" name="password" id="inputPassword" class="form-control" autocomplete="current-password" placeholder="••••••••" required>
                        </div>

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                        <div class="checkbox mb-4 form-check">
                            <input type="checkbox" name="_remember_me" id="_remember_me" class="form-check-input">
                            <label class="form-check-label small text-muted" for="_remember_me">Se souvenir de moi</label>
                        </div>

                        <button class="btn btn-primary w-100 py-2.5 fw-bold shadow-sm" type="submit">
                            <i class="bi bi-box-arrow-in-right"></i> Se connecter
                        </button>
                    </form>

                </div>
            </div>

            <div class="text-center mt-4">
                <p class="text-muted small">Nouveau sur DevisPro ? <a href="{{ path('app_register') }}" class="text-primary fw-semibold text-decoration-none">Créer un compte</a></p>
            </div>

        </div>
    </div>
</div>
{% endblock %}
